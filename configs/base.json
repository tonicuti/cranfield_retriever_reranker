{
  "paths": {
    "docs_dir": "cranfield-dataset/DOCS",
    "queries_file": "cranfield-dataset/query.txt",
    "qrels_dir": "cranfield-dataset/REL",
    "index_dir": "artifacts/indexes/cranfield_minilm",
    "run_dir": "artifacts/runs"
  },
  "indexing": {
    "embedder_model": "sentence-transformers/all-MiniLM-L6-v2",
    "embedding_device": "cpu",
    "normalize_embeddings": true,
    "batch_size": 64,
    "faiss_metric": "cosine",
    "top_k": 100
  },
  "reranking": {
    "enabled": true,
    "model": "cross-encoder/ms-marco-MiniLM-L6-v2",
    "device": "cpu",
    "top_k_candidates": 100,
    "top_k_final": 10
  }
}
